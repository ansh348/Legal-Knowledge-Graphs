        "display_location": "0:11",
        "secondary_spans": [],
        "surface_text": "Başvurucunun itiraz istemi İstanbul Bölge İdare Mahkemesi İkinci Kurulunun (Bölge İdare Mahkemesi) 20/1/2016 tarihli kararı ile reddedilmiştir."
      },
      "fact_type": "procedural",
      "actor_source": "lower_court",
      "date": "2016-01-20",
      "date_approximate": false,
      "disputed_by": null,
      "court_finding": "accepted",
