    {
      "id": "f2",
      "type": "fact",
      "text": "The application was submitted to the Commission after administrative preliminary examination of the application form and annexes.",
      "anchor": {
        "doc_id": "sha256:affcd09b708d",
        "start_char": 332,
        "end_char": 456,
        "text_hash": "433a2d5142c64043",
        "display_location": "0",
        "secondary_spans": [],
        "surface_text": "Başvuru, başvuru formu ve eklerinin idari yönden yapılan ön incelemesinden sonra Komisyona sunulmuştur."
      },
      "fact_type": "procedural",
      "actor_source": "court",
      "date": null,
      "date_approximate": false,
      "disputed_by": null,
      "court_finding": "accepted",
      "confidence": "high",
      "provenance": {
        "extraction_method": "llm",
