        "doc_id": "sha256:affcd09b708d",
        "start_char": 291,
        "end_char": 329,
        "text_hash": "1f7fdf30b76f1d08",
        "display_location": "0",
        "secondary_spans": [],
        "surface_text": "Başvuru 8/5/2017 tarihinde yapılmıştır."
      },
      "fact_type": "procedural",
      "actor_source": "court",
      "date": "2017-05-08",
      "date_approximate": false,
      "disputed_by": null,
      "court_finding": "accepted",
