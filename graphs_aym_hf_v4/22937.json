        "timestamp": "2026-02-17T21:36:57.023378"
      }
    },
    {
      "id": "f3",
      "type": "fact",
      "text": "The Commission decided that the admissibility examination of the application be conducted by the Section.",
      "anchor": {
        "doc_id": "sha256:affcd09b708d",
        "start_char": 459,
        "end_char": 578,
        "text_hash": "93ef96d026bc2ed5",
        "display_location": "0",
        "secondary_spans": [],
        "surface_text": "Komisyonca başvurunun kabul edilebilirlik incelemesinin Bölüm tarafından yapılmasına karar verilmiştir."
      },
      "fact_type": "procedural",
      "actor_source": "court",
      "date": null,
      "date_approximate": false,
      "disputed_by": null,
      "court_finding": "accepted",
      "confidence": "high",
      "provenance": {
        "extraction_method": "llm",
