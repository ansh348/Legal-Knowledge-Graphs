        "timestamp": "2026-02-17T21:36:57.023378"
      }
    },
    {
      "id": "f4",
      "type": "fact",
      "text": "In the examination of the petitioner's legal books and documents, fake invoices were found among the purchase documents.",
      "anchor": {
        "doc_id": "sha256:affcd09b708d",
        "start_char": 686,
        "end_char": 811,
        "text_hash": "15c92c67b90675e5",
        "display_location": "0",
        "secondary_spans": [],
        "surface_text": "Başvurucu adına, yasal defter ve belgeleri üzerinde yapılan incelemede alış belgeleri arasında sahte faturalara rastlanılmıştır."
      },
      "fact_type": "material",
      "actor_source": "petitioner",
      "date": null,
      "date_approximate": false,
      "disputed_by": null,
      "court_finding": "accepted",
      "confidence": "high",
      "provenance": {
        "extraction_method": "llm",
